#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Run linters
echo "🔍 Running linters..."

# Frontend linting
cd frontend
npm run lint
LINT_EXIT=$?

if [ $LINT_EXIT -ne 0 ]; then
  echo "❌ ESLint failed. Please fix the errors before committing."
  exit 1
fi

echo "✅ Linting passed!"

# Run tests
echo "🧪 Running tests..."
npm run test:run
TEST_EXIT=$?

if [ $TEST_EXIT -ne 0 ]; then
  echo "⚠️  Some tests failed. Review before committing."
  # Don't block commit, just warn
fi

echo "✅ Pre-commit checks completed!"
